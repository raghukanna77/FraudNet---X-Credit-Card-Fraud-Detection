# Environment Configuration Template
# Copy this file to .env and fill in your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Paths
DATA_PATH=data/creditcard.csv
MODEL_PATH=models/
LOG_PATH=logs/

# Model Parameters
RANDOM_STATE=42
TEST_SIZE=0.2
VALIDATION_SIZE=0.2

# Cost Matrix (in dollars)
COST_FALSE_NEGATIVE=100000
COST_FALSE_POSITIVE=500

# Drift Detection
DRIFT_DELTA=0.002
DRIFT_WINDOW_SIZE=1000

# Logging
LOG_LEVEL=INFO

# Dashboard
DASHBOARD_PORT=8501
